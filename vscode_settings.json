{
    "C_Cpp.clang_format_fallbackStyle": "Google",
    "C_Cpp.clang_format_style": "file",
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    "C_Cpp.default.compilerPath": "/usr/bin/g++",
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/**",
        "/usr/include/**"
    ],
    "C_Cpp.doxygen.generatedStyle": "/**",
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "cmake.configureOnOpen": false,
    "cmake.pinnedCommands": [
        "workbench.action.tasks.configureTaskRunner",
        "workbench.action.tasks.runTask"
    ],
    "cmake.showOptionsMovedNotification": false,
    "diffEditor.ignoreTrimWhitespace": true,
    "editor.detectIndentation": false,
    "editor.rulers": [
        100
    ],
    "explorer.confirmDelete": false,
    "git.autorefresh": true,
    "git.confirmSync": false,
    "gitlens.launchpad.indicator.enabled": false,
    "indentRainbow.colors": [
        "rgba(255, 255, 64, 0.5)",
        "rgba(127, 255, 127, 0.5)",
        "rgba(255, 127, 255, 0.5)",
        "rgba(79, 236, 236, 0.5)"
    ],
    "indentRainbow.errorColor": "rgba(255,255,255,0.05)",
    "indentRainbow.indicatorStyle": "light",
    "indentRainbow.lightIndicatorStyleLineWidth": 1,
    "peacock.favoriteColors": [
        {
            "name": "Red",
            "value": "#641414"
        },
        {
            "name": "Blue",
            "value": "#141464"
        },
        {
            "name": "Green",
            "value": "#146414"
        },
        {
            "name": "Purple",
            "value": "#3c1464"
        }
    ],
    "psi-header.changes-tracking": {
        "autoHeader": "autoSave",
        "include": [
            "cpp",
            "h",
            "hpp"
        ],
        "isActive": true
    },
    "psi-header.config": {
        "author": "Harrison Chen",
        "authorEmail": "hchen@pdw.ai",
        "blankLinesAfter": 1,
        "company": "PDW",
        "forceToTop": true,
        "initials": "HC"
    },
    "psi-header.templates": [
        {
            "language": "*",
            "template": [
                "-----------------------------------------------",
                "PDW Proprietary and Confidential",
                "-----------------------------------------------",
                "Copyright (c) 2024 Performance Drone Works LLC.",
                "-----------------------------------------------",
                "Created Date: <<filecreated('MM-DD-YYYY')>>",
                "Author: PDW Autonomy",
                "-----------------------------------------------",
                "Last Modified: <<dateformat('MM-DD-YYYY')>>",
                "Modified By: PDW Autonomy",
                "-----------------------------------------------"
            ]
        }
    ],
    "todo-tree.general.showActivityBarBadge": true,
    "todo-tree.highlights.defaultHighlight": {
        "type": "text"
    },
    "todo-tree.regex.regex": "(//|#|<!--|;|/\\*|^|^[ \\t]*(-|\\d+.))\\s*($TAGS)\\(hchen\\):",
    "todo-tree.tree.expanded": true,
    "todo-tree.tree.flat": true,
    "workbench.colorTheme": "Default Dark Modern",
    "workbench.iconTheme": "vscode-icons"
}